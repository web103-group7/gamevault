{
  "name": "gamevault",
  "type": "module",
  "scripts": {
    "predev": "if [ \"$NODE_ENV\" != \"production\" ]; then node server/config/reset.js; fi",
    "dev": "concurrently \"cd client && vite\" \"cd server && nodemon server\"",
    "start": "node server/server.js",
    "build": "cd client && vite build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@picocss/pico": "^1.5.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^7.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "nodemon": "^3.1.14",
    "pg": "^8.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-modal": "^3.16.1",
    "react-router-dom": "^6.9.0",
    "serve-favicon": "^2.5.0",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11"
  }
